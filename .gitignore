# ------------------------------------------------------------------------------
# Dependencies
# ------------------------------------------------------------------------------
/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ------------------------------------------------------------------------------
# Next.js & Build Outputs
# ------------------------------------------------------------------------------
/.next/
/out/
/build/
/dist/
*.tsbuildinfo
next-env.d.ts

# ------------------------------------------------------------------------------
# Environment Variables
# ------------------------------------------------------------------------------
# Always ignore local environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Allow committing example environment files
!.env.example

# ------------------------------------------------------------------------------
# Logs & Debugging
# ------------------------------------------------------------------------------
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# ------------------------------------------------------------------------------
# Testing
# ------------------------------------------------------------------------------
/coverage/
/.nyc_output/

# ------------------------------------------------------------------------------
# IDEs & Editors
# ------------------------------------------------------------------------------
# VS Code
.vscode/*
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json

# JetBrains (IntelliJ, WebStorm, etc.)
.idea/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
[._]*.s[a-v][a-z]
! [._]*.svg
[._]sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]uv[a-z]
[._]sw[a-p]
[._]*.un~

# ------------------------------------------------------------------------------
# OS Files
# ------------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp

# Linux
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ------------------------------------------------------------------------------
# Tools & Deployment
# ------------------------------------------------------------------------------
# Vercel
.vercel

# Biome
.biome/

# Turbopack
.turbo/

# ------------------------------------------------------------------------------
# Project Specific
# ------------------------------------------------------------------------------
# Personal notes
/notes/
.agents/
/portfolio/

